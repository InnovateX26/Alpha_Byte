import os
import cv2
import numpy as np
from flask import Flask, request, jsonify, render_template_string
from flask_cors import CORS
import tensorflow as tf

app = Flask(__name__)
CORS(app)

UPLOAD_FOLDER = "uploads"
os.makedirs(UPLOAD_FOLDER, exist_ok=True)

# ✅ Load trained model
MODEL_PATH = "model.keras"

if not os.path.exists(MODEL_PATH):
    raise FileNotFoundError("❌ model.keras not found in project folder")

model = tf.keras.models.load_model(MODEL_PATH)

# ✅ Preprocess
def preprocess(img):
    img = cv2.resize(img, (64, 64))
    img = img.astype("float32") / 255.0
    img = np.expand_dims(img, axis=0)
    return img

# ✅ Prediction
def analyze_image(path):
    img = cv2.imread(path)

    if img is None:
        return {"error": "Invalid image"}

    img = preprocess(img)
    pred = model.predict(img, verbose=0)[0][0]

    fake = float(pred)
    real = float(1 - pred)

    return {
        "prediction": "AI Generated" if fake > 0.5 else "Real",
        "ai_percentage": round(fake * 100, 2),
        "real_percentage": round(real * 100, 2)
    }

# ✅ INLINE HTML (NO templates folder needed 🚀)
HTML_PAGE = """
<!DOCTYPE html>
<html>
<head>
    <title>TruthLens AI Detector</title>
    <style>
        body {
            font-family: Arial;
            text-align: center;
            background: #0f172a;
            color: white;
        }
        .box {
            background: #1e293b;
            padding: 20px;
            border-radius: 10px;
            display: inline-block;
            margin-top: 50px;
        }
        button {
            padding: 10px;
            background: #38bdf8;
            border: none;
            cursor: pointer;
        }
    </style>
</head>
<body>
    <h1>🔍 TruthLens AI Detection</h1>

    <div class="box">
        <input type="file" id="fileInput"><br><br>
        <button onclick="uploadFile()">Analyze</button>

        <div id="result"></div>
    </div>

    <script>
        function uploadFile() {
            let file = document.getElementById("fileInput").files[0];

            if (!file) {
                alert("Select a file first!");
                return;
            }

            let formData = new FormData();
            formData.append("file", file);

            fetch("/upload", {
                method: "POST",
                body: formData
            })
            .then(res => res.json())
            .then(data => {
                if (data.error) {
                    document.getElementById("result").innerHTML = "❌ " + data.error;
                } else {
                    document.getElementById("result").innerHTML = `
                        <p><b>${data.prediction}</b></p>
                        <p>AI: ${data.ai_percentage}%</p>
                        <p>Real: ${data.real_percentage}%</p>
                    `;
                }
            });
        }
    </script>
</body>
</html>
"""

# ✅ Routes
@app.route("/")
def home():
    return render_template_string(HTML_PAGE)

@app.route("/upload", methods=["POST"])
def upload():
    if "file" not in request.files:
        return jsonify({"error": "No file uploaded"}), 400

    file = request.files["file"]

    if file.filename == "":
        return jsonify({"error": "No file selected"}), 400

    filepath = os.path.join(UPLOAD_FOLDER, file.filename)
    file.save(filepath)

    result = analyze_image(filepath)
    return jsonify(result)

# ✅ Run
if __name__ == "__main__":
    app.run(debug=True)
