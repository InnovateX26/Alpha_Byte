<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>TruthLens AI Detector</title>

<style>
body{
  margin:0;
  font-family: Arial, sans-serif;
  background: linear-gradient(135deg,#0a0f2c, #1e4db7);
  color: white;
  text-align: center;
}
/*HEADER*/
.logo{
height: 200px;
width: 300px;
display: block;
margin: 20px auto;
animation: pulseGlow 1s infinte alternate;
}
logo:hover{
transform: scale(1.05);
filter: drop-shadow(0 0 20px #76dce9);
}
.quote{
   font-size: 25px;
   margin-bottom: 20px;
}
/*UPLOAD BOX*/
.upload-box{
  font-size: 18px;
  margin: 20px auto;
  width:50%;
  padding: 25px;
  border: 2px dashed #dashed #555;
  border-radius: 20px;
}
.upload-box:hover{
  border-color: #00ff99;
}
